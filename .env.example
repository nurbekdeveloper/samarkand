# ── Telegram ──────────────────────────────────────────────
# Get from @BotFather after creating your bot
BOT_TOKEN=1234567890:ABCDefGhIJKlmnoPQRsTUVwxyz

# Telegram ID of your admin group (always negative for groups)
# Send any message to the group, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and look for "chat":{"id": -1001234567890}
ADMIN_GROUP_ID=-1001234567890

# ── Google Sheets ─────────────────────────────────────────
# The long ID from your sheet's URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Path to your service account JSON key file (default: same directory)
GOOGLE_CREDS_FILE=credentials.json
